{
  "version": 2,
  "functions": {
    "api/**/*.js": {
      "runtime": "nodejs18.x"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "env": {
    "NEXT_PUBLIC_SUPABASE_URL": "https://SEU-PROJETO.supabase.co",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY": "SUA_CHAVE_ANONIMA"
  }
}
