{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/admin-panel",
      "destination": "/admin-panel.html"
    },
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ],
  "errorPages": [
    {
      "status": 404,
      "src": "/index.html"
    }
  ]
}
