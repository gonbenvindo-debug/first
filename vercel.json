{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/admin-panel",
      "destination": "/admin-panel.html"
    },
    {
      "source": "/((?!api/|admin-panel).*\\..*)",
      "destination": "/$1"
    },
    {
      "source": "/((?!api/|admin-panel).*)",
      "destination": "/index.html"
    }
  ]
}
